<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HaloPixelToolBox.Views.LXMusicLyricsToolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HaloPixelToolBox.Views"
    NavigationCacheMode="Enabled"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <ScrollView>
            <StackPanel Padding="20" Spacing="24">
                <!-- 页面标题 -->
                <StackPanel Spacing="8">
                    <TextBlock 
                        Text="🎵 落雪音乐歌词工具" 
                        FontSize="32" 
                        FontWeight="Bold"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    <TextBlock 
                        Text="通过落雪音乐的开放 API 将实时歌词显示到 RGB 音响设备" 
                        FontSize="14"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- 设备连接状态卡片 -->
                <Border 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="20"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock 
                            Text="📊 连接状态" 
                            FontSize="16" 
                            FontWeight="SemiBold"/>

                        <Grid ColumnSpacing="24" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <!-- RGB 音响设备状态 -->
                            <StackPanel Spacing="8">
                                <TextBlock 
                                    Text="RGB 音响设备" 
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="12"/>
                                <StackPanel 
                                    Orientation="Horizontal" 
                                    Spacing="8"
                                    Padding="12"
                                    Background="{Binding DeviceReady, Converter={StaticResource BoolToStatusBackgroundConverter}}"
                                    CornerRadius="8">
                                    <TextBlock 
                                        Text="{Binding DeviceReady, Converter={StaticResource BoolToStatusSymbolConverter}}"
                                        FontSize="20"/>
                                    <TextBlock 
                                        Text="{Binding DeviceReady, Converter={StaticResource BoolToStatusTextConverter}}"
                                        FontWeight="SemiBold"
                                        VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- 落雪音乐 API 状态 -->
                            <StackPanel Spacing="8" Grid.Column="1">
                                <TextBlock 
                                    Text="落雪音乐 API" 
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="12"/>
                                <StackPanel 
                                    Orientation="Horizontal" 
                                    Spacing="8"
                                    Padding="12"
                                    Background="{Binding LxmusicReady, Converter={StaticResource BoolToStatusBackgroundConverter}}"
                                    CornerRadius="8">
                                    <TextBlock 
                                        Text="{Binding LxmusicReady, Converter={StaticResource BoolToStatusSymbolConverter}}"
                                        FontSize="20"/>
                                    <TextBlock 
                                        Text="{Binding LxmusicStatus}"
                                        FontWeight="SemiBold"
                                        VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 当前歌曲信息卡片 -->
                <Border 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="20"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock 
                            Text="🎼 当前歌曲" 
                            FontSize="16" 
                            FontWeight="SemiBold"/>

                        <!-- 歌曲信息 -->
                        <StackPanel 
                            Padding="12"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="8"
                            Spacing="8">
                            <TextBlock 
                                Text="{Binding CurrentSongInfo}" 
                                FontSize="14"
                                FontWeight="Medium"
                                TextTrimming="CharacterEllipsis"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock 
                                Text="{Binding CurrentSongInfo, Converter={StaticResource StringEmptyConverter}}"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>

                        <!-- 当前歌词 -->
                        <StackPanel Spacing="8">
                            <TextBlock 
                                Text="当前歌词" 
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Border 
                                Padding="12"
                                Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                CornerRadius="8"
                                MinHeight="60">
                                <TextBlock 
                                    Text="{Binding CurrentLyric}" 
                                    FontSize="13"
                                    TextWrapping="WrapWholeWords"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    FontStyle="Italic"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- API 配置卡片 -->
                <Border 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="20"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock 
                            Text="⚙️ API 配置" 
                            FontSize="16" 
                            FontWeight="SemiBold"/>

                        <InfoBar 
                            Title="默认配置"
                            Message="落雪音乐默认在本地 localhost:23333 提供 OpenAPI 服务"
                            Severity="Informational"
                            IsOpen="True"
                            IsClosable="False"/>

                        <!-- API Host 输入 -->
                        <StackPanel Spacing="6">
                            <TextBlock 
                                Text="API 服务器地址" 
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBox 
                                Text="{Binding ApiHost, Mode=TwoWay}"
                                PlaceholderText="localhost"
                                Header="Host"/>
                        </StackPanel>

                        <!-- API Port 输入 -->
                        <StackPanel Spacing="6">
                            <TextBlock 
                                Text="API 服务器端口" 
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <NumberBox 
                                Value="{Binding ApiPort, Mode=TwoWay}"
                                Minimum="1"
                                Maximum="65535"
                                Header="Port"
                                SmallChange="1"
                                LargeChange="100"/>
                        </StackPanel>

                        <!-- 更新间隔 -->
                        <StackPanel Spacing="6">
                            <TextBlock 
                                Text="更新间隔（毫秒）" 
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <NumberBox 
                                Value="{Binding UpdateInterval, Mode=TwoWay}"
                                Minimum="50"
                                Maximum="1000"
                                SmallChange="50"
                                LargeChange="100"
                                Header="Interval"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 功能开关卡片 -->
                <Border 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="20"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock 
                            Text="🎛️ 功能设置" 
                            FontSize="16" 
                            FontWeight="SemiBold"/>

                        <!-- 启用歌词显示 -->
                        <StackPanel Spacing="4">
                            <ToggleSwitch 
                                Header="启用歌词显示"
                                IsOn="{Binding EnableLXMusicLyrics, Mode=TwoWay}"/>
                            <TextBlock 
                                Text="启用后，工具将实时读取落雪音乐的歌词并显示到 RGB 音响设备"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- 暂停时切换回时钟界面 -->
                        <StackPanel Spacing="4">
                            <ToggleSwitch 
                                Header="暂停时切换回时钟界面"
                                IsOn="{Binding SwitchBackWhenPause, Mode=TwoWay}"/>
                            <TextBlock 
                                Text="当音乐暂停超过指定时间后，自动切换回时钟界面显示"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- 切换延迟设置 -->
                        <StackPanel Spacing="8">
                            <TextBlock 
                                Text="暂停后切换延迟（秒）" 
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Slider 
                                Value="{Binding SwitchBackTimeout, Mode=TwoWay}"
                                Minimum="5"
                                Maximum="60"
                                Step="5"
                                TickPlacement="Outside"
                                TickFrequency="5"/>
                            <TextBlock 
                                Text="{Binding SwitchBackTimeout, StringFormat='切换延迟: {0} 秒'}"
                                FontSize="13"
                                FontWeight="Medium"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 快速帮助卡片 -->
                <Border 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="20"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock 
                            Text="❓ 快速帮助" 
                            FontSize="16" 
                            FontWeight="SemiBold"/>

                        <StackPanel Spacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock 
                                    Text="1. 启用落雪音乐 OpenAPI"
                                    FontWeight="SemiBold"/>
                                <TextBlock 
                                    Text="打开落雪音乐 → 设置 → 开发者选项 → 启用 OpenAPI 服务"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock 
                                    Text="2. 检查连接"
                                    FontWeight="SemiBold"/>
                                <TextBlock 
                                    Text="上面的连接状态应该显示 ✓ 已连接。如果未连接，请检查 API 地址和端口配置"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock 
                                    Text="3. 开始使用"
                                    FontWeight="SemiBold"/>
                                <TextBlock 
                                    Text="在落雪音乐中播放音乐，歌词将实时显示到 RGB 音响设备"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <InfoBar 
                            Title="提示"
                            Message="如遇到问题，请检查防火墙设置、落雪音乐版本和 API 服务状态"
                            Severity="Warning"
                            IsOpen="True"
                            IsClosable="False"/>
                    </StackPanel>
                </Border>

                <!-- 底部间距 -->
                <StackPanel Height="20"/>
            </StackPanel>
        </ScrollView>
    </Grid>
</Page>
